// report summary for only counts; each items -ve / +ve / largely.
const getUniquePifsCount = async (req, res) => {
    try {
        const id = req.params.id;

        const summary = await InspectionScore.findAll({
            attributes: [
                'category',
                'isNegative',
                [Sequelize.fn('COUNT', Sequelize.col('inspection_scores.id')), 'count']
            ],
            where: {
                status: 'active'
            },
            include: [
                {
                    model: InspectionQuestions,
                    attributes: [],
                    where: {
                        inspection_id: id,
                        status: 'active'
                    }
                }
            ],
            group: ['category', 'isNegative']
        });

        // 🔁 Convert to clean response
        const result = {
            human: { negative: 0, positive: 0, largely: 0 },
            process: { negative: 0, largely: 0 },
            hardware: { negative: 0 },
            photo: { negative: 0 }
        };

        summary.forEach(item => {
            const category = item.category?.toLowerCase();
            const type = item.isNegative?.toLowerCase();
            const count = Number(item.get('count'));

            if (category === 'human') {
                if (type === 'yes') result.human.negative = count;
                if (type === 'no') result.human.positive = count;
                if (type === 'largely') result.human.largely = count;
            }

            if (category === 'process') {
                if (type === 'yes') result.process.negative = count;
                if (type === 'largely') result.process.largely = count;
            }

            if (category === 'hardware') {
                if (type === 'yes') result.hardware.negative = count;
            }

            if (category === 'photo') {
                if (type === 'yes') result.photo.negative = count;
            }
        });

        return res.status(200).json({
            success: true,
            data: result
        });

    } catch (err) {
        console.log(err);
        return res.status(500).json({
            success: false,
            message: err.message
        });
    }
};